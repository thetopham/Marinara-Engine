# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
*.tsbuildinfo

# Database (contains all user data: chats, characters, lorebooks, presets, connections, agents, etc.)
*.db
*.db-shm
*.db-wal
*.db-journal

# Environment (may contain encryption keys)
.env
.env.local
.env.production

# Project pnpm config is tracked. The Termux launcher may append local platform
# fixes to it on Android installs.
!.npmrc

# IDE
.vscode/settings.json
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# User data — uploaded avatars, backgrounds, sprites, and runtime files
data/
packages/server/data/

# Logs
*.log

# Custom agents (personal)
.github/agents/qa.agent.md

# Build output
release/
release-artifacts/

# Installer artifacts are published on GitHub Releases, not tracked in source
installer/*.exe
win/installer/*.exe

# Local docker compose overrides (per-machine dev config)
docker-compose.override.yml
docker-compose.override.yaml
